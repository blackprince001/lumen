# Papers Application Configuration
# Copy this file to .env and fill in your values

GOOGLE_API_KEY=

# ─── PAPER DISCOVERY (optional) ────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
SERPAPI_KEY=
OPENALEX_API_KEY=

# ─── DATABASE ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=papers

# ─── REDIS (broker for Celery + task status) ──────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── APPLICATION ───────────────────────────────────────────────────────────────
DEBUG=false
PORT=8000
STORAGE_PATH=/app/storage/papers
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

# ─── JWT AUTH ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=
AI_KEY_ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── ADMIN (base64-encoded credentials) ───────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── FRONTEND ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://testing.maurc.org
APP_URL=http://testing.maurc.org
VITE_API_URL=http://api.testing.maurc.org/api/v1
VITE_GOOGLE_CLIENT_ID=

# ─── EMAIL (Resend — optional, off by default) ────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_ENABLED=false

# ─── DEEP RESEARCH (experimental) ─────────────────────────────────────────────
ENABLE_DEEP_RESEARCH=false

# ─── PRODUCTION DOMAINS (used in docker-compose.prod.yml) ─────────────────────
LETSENCRYPT_EMAIL=
TRAEFIK_DOMAIN=traefik.yourdomain.com
BACKEND_DOMAIN=api.yourdomain.com
FRONTEND_DOMAIN=papers.yourdomain.com
