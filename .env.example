# Papers Application Configuration
# Copy this file to .env and fill in your values

# REQUIRED: AI Model Provider
GOOGLE_API_KEY=your_google_api_key_here

# OPTIONAL: Paper Search & Discovery
SEMANTIC_SCHOLAR_API_KEY=
SERPAPI_KEY=

# DATABASE CONFIGURATION
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=papers

# REDIS CONFIGURATION
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# APPLICATION SETTINGS
DEBUG=false
PORT=8000
STORAGE_PATH=/app/storage/papers

# AUTH: JWT
JWT_SECRET_KEY=your_jwt_secret_key_here

# AUTH: Admin credentials (base64-encoded values)
ADMIN_USERNAME=your_base64_encoded_username
ADMIN_PASSWORD=your_base64_encoded_password

# AUTH: Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# FRONTEND
FRONTEND_URL=http://testing.maurc.org
VITE_API_URL=http://api.testing.maurc.org/api/v1
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# PRODUCTION: Let's Encrypt Configuration
LETSENCRYPT_EMAIL=your-email@example.com

# PRODUCTION: Domain Configuration
TRAEFIK_DOMAIN=traefik.yourdomain.com
BACKEND_DOMAIN=api.yourdomain.com
FRONTEND_DOMAIN=papers.yourdomain.com
