# Backend environment — sourced by docker compose from root .env
# All variables are defined in the root .env.example at the project root.
# This file exists as a reference; see ../.env.example for the full list.
#
# Key vars that MUST be set:
#   GOOGLE_API_KEY | OPENAI_API_KEY | ANTHROPIC_API_KEY | DEEPSEEK_API_KEY
#   DATABASE_URL (or DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME)
#   JWT_SECRET_KEY
#   GOOGLE_CLIENT_ID
